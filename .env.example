# API Keys for different LLM Providers
# Uncomment and set the keys for the providers you wish to use

# MINIMAX_API_KEY="your_minimax_key"
# OPENAI_API_KEY="your_openai_key"
# ANTHROPIC_API_KEY="your_anthropic_key"
# GEMINI_API_KEY="your_gemini_key"
# KIMI_API_KEY="your_kimi_key"
# DEEPSEEK_API_KEY="your_deepseek_key"

# Web Search Backend (optional, auto-detected by priority)
# If none are set, DuckDuckGo is used as a free fallback
# TAVILY_API_KEY="tvly-..."       # Recommended: AI-optimized, 1000 free/month
# BRAVE_API_KEY="BSA..."          # Privacy-focused, 2000 free/month
# SERPAPI_API_KEY="..."           # Google results via API

# Language Preference (optional)
# Set to make the agent respond in your preferred language
# CLAW_LANGUAGE="chinese"         # e.g. japanese, spanish, korean, etc.
